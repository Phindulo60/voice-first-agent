# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock Model
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# Polly Voice
POLLY_VOICE_ID=Matthew
POLLY_ENGINE=neural

# Whisper Model Size (tiny, base, small, medium, large-v3)
WHISPER_MODEL=base

# Audio Settings
SAMPLE_RATE=16000
CHANNELS=1
