# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock Model
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# F5-TTS Configuration
# Device: cpu, cuda, or mps (Apple Silicon)
TTS_DEVICE=mps
# Reference audio for voice cloning (leave empty for built-in default)
TTS_REF_AUDIO=
# Transcript of reference audio (leave empty for auto-transcription)
TTS_REF_TEXT=

# NLLB Translation Model
# Options: facebook/nllb-200-distilled-600M (light), facebook/nllb-200-1.3B, facebook/nllb-200-3.3B (best)
NLLB_MODEL=facebook/nllb-200-distilled-600M
MT_DEVICE=cpu

# Whisper Model Size (tiny, base, small, medium, large-v3)
WHISPER_MODEL=base

# MMS Model for Zulu ASR
# Default: facebook/mms-1b-all (generic multilingual + Zulu adapter, degrades on long utterances)
# Better option once HF access is approved (still pending as of 2026-07-15, see issue #2):
#   asr-africa/mms-1B_all_NCHLT_ZULU_50hr_v1 — fine-tuned on 50hrs NCHLT-Zulu corpus, ~20% WER
MMS_MODEL=facebook/mms-1b-all

# Hugging Face Token (for model downloads)
HF_TOKEN=

# Audio Settings
SAMPLE_RATE=16000
CHANNELS=1

# Safety Layer (confidence-gated confirm-back)
SAFETY_ENABLED=true
SAFETY_HIGH_THRESHOLD=0.75
SAFETY_LOW_THRESHOLD=0.50

# TTS Engine: 'mms' (native Zulu, fast, small) or 'f5' (voice cloning, slower)
TTS_ENGINE=mms
MMS_TTS_MODEL=facebook/mms-tts-zul
