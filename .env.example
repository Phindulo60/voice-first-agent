# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock Model
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# F5-TTS Configuration
# Device: cpu, cuda, or mps (Apple Silicon)
TTS_DEVICE=mps
# Reference audio for voice cloning (leave empty for built-in default)
TTS_REF_AUDIO=
# Transcript of reference audio (leave empty for auto-transcription)
TTS_REF_TEXT=

# NLLB Translation Model
# Options: facebook/nllb-200-distilled-600M (light), facebook/nllb-200-1.3B, facebook/nllb-200-3.3B (best)
NLLB_MODEL=facebook/nllb-200-distilled-600M
MT_DEVICE=cpu

# Whisper Model Size (tiny, base, small, medium, large-v3)
WHISPER_MODEL=base

# Hugging Face Token (for model downloads)
HF_TOKEN=

# Audio Settings
SAMPLE_RATE=16000
CHANNELS=1
